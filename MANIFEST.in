# Include documentation
include README.md
include LICENSE
include requirements.txt
include pyproject.toml

# Include documentation directories
recursive-include docs *.md
recursive-include docs *.pdf

# Include testing, tools, and benchmarks
recursive-include tests *.py
recursive-include tools *.py
recursive-include tools *.js
recursive-include tools *.json
recursive-include tools *.md
recursive-include tools *.rs
recursive-include tools *.toml
recursive-include benchmarks *.py
recursive-include benchmarks *.json

# Exclude examples from distribution (they require running servers)
# recursive-include examples *.py
# recursive-include examples *.md

# Exclude archive and github from distribution
recursive-exclude archive *
recursive-exclude .github *

# Exclude build artifacts
global-exclude __pycache__
global-exclude *.py[co]
global-exclude *.so
global-exclude .DS_Store

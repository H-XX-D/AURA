{
  "name": "aura-compression-native",
  "version": "1.1.4",
  "description": "AURA Protocol - Native Node.js bindings for high-performance compression",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "aura-native",
    "triples": {
      "additional": [
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node test.js",
    "universal": "napi universal",
    "version": "napi version"
  },
  "keywords": [
    "compression",
    "ai",
    "audit",
    "native",
    "napi",
    "rust",
    "performance",
    "template",
    "semantic"
  ],
  "author": "Todd Hendricks <todd@auraprotocol.org>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/hendrixx-cnc/AURA.git"
  },
  "bugs": {
    "url": "https://github.com/hendrixx-cnc/AURA/issues"
  },
  "homepage": "https://auraprotocol.org",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  },
  "engines": {
    "node": ">= 16"
  },
  "optionalDependencies": {
    "@aura-protocol/native-win32-x64-msvc": "1.0.1",
    "@aura-protocol/native-darwin-x64": "1.0.1",
    "@aura-protocol/native-linux-x64-gnu": "1.0.1",
    "@aura-protocol/native-darwin-arm64": "1.0.1",
    "@aura-protocol/native-linux-arm64-gnu": "1.0.1",
    "@aura-protocol/native-linux-arm64-musl": "1.0.1",
    "@aura-protocol/native-win32-arm64-msvc": "1.0.1",
    "@aura-protocol/native-linux-x64-musl": "1.0.1"
  }
}
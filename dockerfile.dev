# Development Dockerfile with all build tools

FROM python:3.11-slim

# Install all build dependencies
RUN apt-get update && apt-get install -y \
    curl \
    gcc \
    g++ \
    make \
    cmake \
    git \
    ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y \
    && rm -rf /var/lib/apt/lists/*

# Add Rust to PATH
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /app

# Install Python dependencies
COPY requirements.txt pyproject.toml setup.py README.md ./
RUN pip install --no-cache-dir -e ".[dev,websocket]" && \
    pip install --no-cache-dir debugpy watchdog

# Copy source code (Python only for dev server)
COPY . .

# Note: Node.js dependencies are not needed for Python tests/server. Skip npm install to avoid native build failures.

# Note: Skipping Rust and Node builds in dev image since the Python server
# does not depend on the Node addon or Rust binaries. This keeps builds fast
# and avoids failing on missing native sources.

# Create data and logs directories
RUN mkdir -p /app/data /app/logs

EXPOSE 8765 5678

CMD ["python", "production_websocket_server.py"]

{
  "name": "@aura-protocol/native",
  "version": "1.0.0",
  "description": "AI-Optimized Hybrid Compression Protocol for Real-Time Communication",
  "main": "tools/packages/aura-node-native/index.js",
  "types": "tools/packages/aura-node-native/index.d.ts",
  "bin": {
    "aura-compress": "tools/packages/aura-node-native/bin/compress.js",
    "aura-decompress": "tools/packages/aura-node-native/bin/decompress.js"
  },
  "files": [
    "tools/packages/aura-node-native/index.js",
    "tools/packages/aura-node-native/index.d.ts",
    "tools/packages/aura-node-native/aura-native.darwin-arm64.node",
    "tools/packages/aura-node-native/aura-native.darwin-x64.node",
    "tools/packages/aura-node-native/aura-native.linux-x64-gnu.node",
    "tools/packages/aura-node-native/aura-native.linux-arm64-gnu.node",
    "tools/packages/aura-node-native/aura-native.win32-x64-msvc.node",
    "lib/**/*",
    "native/**/*",
    "bin/**/*",
    "README.md",
    "LICENSE",
    "INSTALL.md"
  ],
  "scripts": {
    "build": "cd tools/packages/aura-node-native && npm run build",
    "build:all": "npm run build && npm run build:python && npm run build:docs",
    "build:python": "cd src/python && python setup.py build_ext --inplace",
    "build:docs": "typedoc --out docs/api src/**/*.ts",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "test:performance": "jest --testPathPattern=performance",
    "lint": "eslint src/**/*.ts --ext .ts,.js --fix",
    "lint:check": "eslint src/**/*.ts --ext .ts,.js",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test && npm run lint:check",
    "install": "node-gyp-build",
    "postinstall": "node tools/scripts/postinstall.js",
    "docker:build": "docker build -f config/dockerfile -t aura/compression .",
    "docker:run": "docker run -p 8765:8765 aura/compression",
    "docker:test": "docker run --rm aura/compression npm test",
    "clean": "rm -rf lib/ build/ dist/ *.tgz",
    "dev": "nodemon --exec ts-node src/examples/server.ts",
    "benchmark": "node tools/scripts/benchmark.js",
    "audit": "npm audit && node tools/scripts/security-audit.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hendrixx-cnc/AURA.git"
  },
  "keywords": [
    "compression",
    "ai",
    "chat",
    "websocket",
    "auralite",
    "semantic-compression",
    "template-compression",
    "bandwidth-optimization",
    "gdpr",
    "hipaa",
    "compliance",
    "real-time",
    "hybrid-compression",
    "data-optimization"
  ],
  "author": "Todd Hendricks <todd@auraprotocol.org>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/hendrixx-cnc/AURA/issues"
  },
  "homepage": "https://github.com/hendrixx-cnc/AURA#readme",
  "dependencies": {
    "node-addon-api": "^8.1.0",
    "node-gyp-build": "^4.8.1",
    "ws": "^8.16.0",
    "uuid": "^9.0.1",
    "debug": "^4.3.4",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.7",
    "@types/debug": "^4.1.12",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "node-gyp": "^10.0.1",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "typedoc": "^0.25.7",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "rimraf": "^5.0.5",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64",
    "ia32"
  ],
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/aura-compression"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "type": "commonjs"
}

{
  "name": "medicine-cabinet",
  "displayName": "Medicine Cabinet",
  "description": "AI Agent Memory System - Portable Tablets and Context Capsules",
  "version": "0.1.0",
  "publisher": "hendrixx-cnc",
  "repository": {
    "type": "git",
    "url": "https://github.com/hendrixx-cnc/AURA"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "copilot",
    "memory",
    "context",
    "agent"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "medicineCabinet.createCapsule",
        "title": "Medicine Cabinet: Create Context Capsule"
      },
      {
        "command": "medicineCabinet.createTablet",
        "title": "Medicine Cabinet: Create Tablet"
      },
      {
        "command": "medicineCabinet.viewCapsule",
        "title": "Medicine Cabinet: View Context Capsule"
      },
      {
        "command": "medicineCabinet.viewTablet",
        "title": "Medicine Cabinet: View Tablet"
      },
      {
        "command": "medicineCabinet.setTaskObjective",
        "title": "Medicine Cabinet: Set Task Objective"
      },
      {
        "command": "medicineCabinet.addRelevantFiles",
        "title": "Medicine Cabinet: Add Relevant Files"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "medicine-cabinet",
          "title": "Medicine Cabinet",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "medicine-cabinet": [
        {
          "id": "capsules",
          "name": "Context Capsules"
        },
        {
          "id": "tablets",
          "name": "Tablets"
        }
      ]
    },
    "configuration": {
      "title": "Medicine Cabinet",
      "properties": {
        "medicineCabinet.capsulesPath": {
          "type": "string",
          "default": ".aura_context",
          "description": "Path to store context capsules (relative to workspace root)"
        },
        "medicineCabinet.tabletsPath": {
          "type": "string",
          "default": "~/.aura/tablets",
          "description": "Path to store tablets (global memory)"
        },
        "medicineCabinet.autoSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically save context changes"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "eslint": "^8.47.0",
    "typescript": "^5.1.6",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.4.4"
  },
  "dependencies": {}
}

# Multi-stage Docker build for AURA Compression
# Supports Python, Rust, and Node.js components

# =============================================================================
# Base stage with common dependencies
# =============================================================================
FROM ubuntu:22.04 AS base

# Set environment variables
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    git \
    pkg-config \
    libssl-dev \
    python3-dev \
    python3-pip \
    python3-venv \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Set Python 3 as default
RUN ln -sf /usr/bin/python3 /usr/bin/python

# =============================================================================
# Python build stage
# =============================================================================
FROM base AS python-build

WORKDIR /app

# Copy Python requirements
COPY requirements.txt requirements-dev.txt pyproject.toml setup.py ./
COPY aura_compression/ ./aura_compression/

# Create virtual environment and install dependencies
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN pip install --upgrade pip setuptools wheel && \
    pip install -r requirements.txt && \
    pip install -e .

# Build Python extensions
RUN python setup.py build_ext --inplace

# =============================================================================
# Rust build stage
# =============================================================================
FROM rust:1.75-slim AS rust-build

WORKDIR /app/src/rust

# Copy Rust source
COPY src/rust/Cargo.toml src/rust/Cargo.lock ./
COPY src/rust/src/ ./src/

# Build Rust components
RUN cargo build --release --target-dir /app/target

# =============================================================================
# Node.js build stage
# =============================================================================
FROM node:20-slim AS node-build

WORKDIR /app

# Copy Node.js configuration
COPY package.json package-lock.json* ./
COPY tools/packages/aura-node-native/ ./tools/packages/aura-node-native/

# Install dependencies and build
RUN npm ci && \
    npm run build

# =============================================================================
# Runtime stage
# =============================================================================
FROM base AS runtime

# Install runtime dependencies only
RUN apt-get update && apt-get install -y \
    python3 \
    nodejs \
    npm \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create application user
RUN useradd --create-home --shell /bin/bash app

# Copy Python virtual environment
COPY --from=python-build /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy Rust binaries
COPY --from=rust-build /app/target/release/ /usr/local/bin/

# Copy Node.js build
COPY --from=node-build /app/tools/packages/aura-node-native/lib/ /app/lib/
COPY --from=node-build /app/tools/packages/aura-node-native/bin/ /app/bin/

# Copy application code
COPY aura_compression/ /app/aura_compression/
COPY config/ /app/config/
COPY tools/ /app/tools/

# Set working directory
WORKDIR /app

# Create necessary directories
RUN mkdir -p /app/logs /app/data /app/results && \
    chown -R app:app /app

# Switch to non-root user
USER app

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import aura_compression; print('AURA Compression is healthy')" || exit 1

# Expose ports
EXPOSE 8765 8080

# Default command
CMD ["python", "-m", "aura_compression.cli.server", "--host", "0.0.0.0", "--port", "8765"]

# =============================================================================
# Development stage
# =============================================================================
FROM runtime AS development

# Switch back to root for development
USER root

# Install development tools
RUN apt-get update && apt-get install -y \
    git \
    vim \
    htop \
    && rm -rf /var/lib/apt/lists/*

# Install Python development dependencies
RUN pip install pytest pytest-cov black isort mypy flake8

# Install Node.js development dependencies
RUN npm install -g typescript @typescript-eslint/eslint-plugin @typescript-eslint/parser eslint prettier nodemon

# Switch back to app user
USER app

# Development command
CMD ["python", "-m", "aura_compression.cli.server", "--host", "0.0.0.0", "--port", "8765", "--debug"]

# =============================================================================
# Benchmark stage
# =============================================================================
FROM runtime AS benchmark

# Install benchmark dependencies
RUN pip install numpy pandas matplotlib seaborn psutil

# Copy benchmark scripts
COPY benchmarks/ /app/benchmarks/
COPY test_*_benchmark*.py /app/

# Benchmark command
CMD ["python", "/app/benchmarks/run_benchmarks.py"]

# =============================================================================
# Production stage (default)
# =============================================================================
FROM runtime AS production

# Add production optimizations
ENV PYTHONOPTIMIZE=1

# Use production command
CMD ["python", "-m", "aura_compression.cli.server", "--host", "0.0.0.0", "--port", "8765", "--production"]

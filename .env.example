# AURA Compression Environment Configuration
# Copy this file to .env and customize the values

# =============================================================================
# AURA Compression Settings
# =============================================================================

# Server Configuration
AURA_HOST=0.0.0.0
AURA_PORT=8765
AURA_DEBUG=false
AURA_LOG_LEVEL=info

# Security & Compliance
AURA_ENABLE_AUDIT=true
AURA_ENABLE_ENCRYPTION=true
AURA_SESSION_TIMEOUT=3600
AURA_MAX_CONNECTIONS=1000

# Template Management
AURA_TEMPLATE_STORE=/data/templates.json
AURA_TEMPLATE_CACHE_SIZE=1000
AURA_TEMPLATE_AUTO_UPDATE=true

# Performance Tuning
AURA_COMPRESSION_LEVEL=6
AURA_BUFFER_SIZE=65536
AURA_MAX_MESSAGE_SIZE=10485760
AURA_WORKER_THREADS=4

# Metrics & Monitoring
AURA_METRICS_ENABLED=true
AURA_METRICS_INTERVAL=30
AURA_PROMETHEUS_PORT=9090

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL
POSTGRES_DB=aura_compression
POSTGRES_USER=aura
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=change_this_secure_password
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# External Services
# =============================================================================

# Grafana
GRAFANA_PASSWORD=change_this_secure_password

# SSL/TLS (if using nginx proxy)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# =============================================================================
# Development Settings
# =============================================================================

# Node.js Debug Port
NODE_DEBUG_PORT=9229

# Python Development
PYTHONPATH=/app
PYTHONDONTWRITEBYTECODE=1

# =============================================================================
# Benchmark Configuration
# =============================================================================

AURA_BENCHMARK_ITERATIONS=1000
AURA_BENCHMARK_CONCURRENT=10
AURA_BENCHMARK_DATA_SIZE=1024
AURA_BENCHMARK_DURATION=60

# =============================================================================
# Legacy AURA Protocol Tuning (for backward compatibility)
# =============================================================================

# Enable detailed server-side auditing (true/false)
# AURA_ENABLE_AUDIT=true

# Override adaptive refresh threshold (default: 32)
# AURA_ADAPTIVE_REFRESH_THRESHOLD=48

# Override minimum size required before compression (default: 200 bytes)
# AURA_MIN_COMPRESSION_SIZE=150

# Tune literal handling thresholds
# AURA_LITERAL_FREQUENCY_THRESHOLD=0.005
# AURA_MIN_ADAPTIVE_OCCURRENCES=2
# AURA_MIN_ADAPTIVE_WORD_LENGTH=8

# Adjust Huffman base frequencies
# AURA_WORD_BASE_FREQUENCY=3
# AURA_LITERAL_BASE_FREQUENCY=2

# Provide a custom literal whitelist (raw string of characters)
# AURA_COMMON_LITERALS=abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789

# Load full preset configuration from JSON
# AURA_CONFIG_PATH=./config/ai_streaming.json

# CDIS encoder tuning (existing support)
# CDIS_SMALL_FAST_THRESHOLD=1000

# =============================================================================
# Docker Compose Profiles
# =============================================================================

# Available profiles: dev, benchmark, monitoring, logging, proxy
# Set COMPOSE_PROFILES in your shell or use --profile flag
# Example: COMPOSE_PROFILES=dev,monitoring docker-compose up

# =============================================================================
# Security Notes
# =============================================================================
# IMPORTANT: Change all default passwords before deploying to production!
# Use strong, unique passwords for all services.
# Consider using Docker secrets for sensitive data in production.
# Enable SSL/TLS in production environments.
# Regularly rotate credentials and monitor access logs.
